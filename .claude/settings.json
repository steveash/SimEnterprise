{
  "permissions": {
    "allow": [
      "Bash(./scripts/gate.sh:*)",
      "Bash(bash scripts/gate.sh:*)",
      "Bash(uv sync:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run enterprise-sim:*)",
      "Bash(uv run python scripts/import_smoke.py:*)",
      "Bash(make:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}

{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "lib": ["ES2023"],
    "noEmit": true
  },
  "include": ["src/main", "src/preload", "src/sidecar", "src/shared", "electron.vite.config.ts"]
}
